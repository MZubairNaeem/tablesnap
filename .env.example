# Supabase project credentials (Settings -> API in the Supabase dashboard)
# Modern Supabase projects (created after Nov 2025) issue publishable/secret
# keys instead of the legacy anon/service_role JWTs. If you're on an older
# project, use your anon key for NUXT_PUBLIC_SUPABASE_KEY -- the client code
# doesn't care which key format it gets.
NUXT_PUBLIC_SUPABASE_URL=
NUXT_PUBLIC_SUPABASE_KEY=

# Base URL used to build public collection links (/c/[slug]) and QR codes.
NUXT_PUBLIC_SITE_URL=http://localhost:3000
